<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item {{item.isCenter ? 'center-item' : ''}} {{selected === index ? 'active' : ''}}"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <block wx:if="{{item.isCenter}}">
      <image
        class="center-icon"
        src="{{selected === index ? item.selectedIconPath : item.iconPath}}"
        mode="aspectFit"
      />
      <text class="center-text">{{item.text}}</text>
    </block>
    <block wx:else>
      <image
        class="tab-icon"
        src="{{selected === index ? item.selectedIconPath : item.iconPath}}"
        mode="aspectFit"
      />
      <text class="tab-text">{{item.text}}</text>
    </block>
  </view>
</view>
