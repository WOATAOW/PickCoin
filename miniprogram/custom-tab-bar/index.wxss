.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: flex-end;
  justify-content: space-around;
  height: 110rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 999;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0 8rpx;
  position: relative;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 20rpx;
  color: #9CA3AF;
  line-height: 1.2;
}

.tab-item.active .tab-text {
  color: #1E3A8A;
  font-weight: 600;
}

/* ========== Center Button ========== */
.center-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 4rpx;
}

.center-text {
  font-size: 20rpx;
  color: #9CA3AF;
  line-height: 1.2;
}

.center-item.active .center-text {
  color: #1E3A8A;
  font-weight: 600;
}
