page {
  background-color: #F3F4F6;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  margin: 0;
  padding: 0;
  min-height: 100vh;
}

.about-container {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ========== Header ========== */
.header {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 36rpx rgba(102, 126, 234, 0.3);
  overflow: hidden;
}

.header-bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.1;
  background: #fff;
}

.header-bg-circle.c1 {
  width: 200rpx;
  height: 200rpx;
  top: -50rpx;
  right: -30rpx;
}

.header-bg-circle.c2 {
  width: 140rpx;
  height: 140rpx;
  bottom: -20rpx;
  left: -20rpx;
}

.header-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-wrap {
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.logo {
  font-size: 56rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
}

/* ========== Section Title ========== */
.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 24rpx;
}

.section-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section-icon-wrap.blue-bg {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
}

.section-icon-wrap.amber-bg {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
}

.section-icon-wrap.green-bg {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
}

.section-icon {
  font-size: 26rpx;
}

/* ========== Cards ========== */
.feature-card,
.usage-card,
.tech-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* ========== Feature List ========== */
.feature-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.feature-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #F9FAFB;
  border-radius: 20rpx;
}

.feature-icon {
  width: 76rpx;
  height: 76rpx;
  background: linear-gradient(135deg, #E0E7FF 0%, #C7D2FE 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.feature-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
}

/* ========== Example List ========== */
.example-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.example-item {
  display: flex;
  align-items: center;
  padding: 18rpx 20rpx;
  background: #FFFBEB;
  border-radius: 16rpx;
  border-left: 6rpx solid #F59E0B;
}

.example-query {
  font-size: 26rpx;
  color: #6B7280;
  flex: 1;
}

.example-arrow {
  font-size: 24rpx;
  color: #D1D5DB;
  margin: 0 16rpx;
}

.example-result {
  font-size: 26rpx;
  color: #059669;
  font-weight: 600;
}

/* ========== Tech List ========== */
.tech-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.tech-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 20rpx;
  background: #F0FDF4;
  border-radius: 16rpx;
}

.tech-label {
  font-size: 26rpx;
  color: #6B7280;
}

.tech-value {
  font-size: 26rpx;
  color: #059669;
  font-weight: 600;
}

/* ========== Footer ========== */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 16rpx;
  gap: 8rpx;
}

.version {
  font-size: 24rpx;
  color: #9CA3AF;
}

.copyright {
  font-size: 22rpx;
  color: #D1D5DB;
}
