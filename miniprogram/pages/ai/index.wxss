page {
  height: 100%;
  background-color: #F3F4F6;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F3F4F6;
}

.scroll-area {
  flex: 1;
  height: 0;
  box-sizing: border-box;
}

.chat-content {
  padding: 24rpx;
  min-height: 100%;
  display: flex;
  flex-direction: column;
}

.bottom-spacer {
  height: 20rpx;
  width: 100%;
}

/* ========== Welcome Section ========== */
.welcome-section {
  position: relative;
  margin: 40rpx 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 28rpx;
  padding: 48rpx 36rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 36rpx rgba(102, 126, 234, 0.3);
}

.welcome-bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.1;
  background: #fff;
}

.welcome-bg-circle.c1 {
  width: 200rpx;
  height: 200rpx;
  top: -60rpx;
  right: -40rpx;
}

.welcome-bg-circle.c2 {
  width: 140rpx;
  height: 140rpx;
  bottom: -20rpx;
  left: -30rpx;
}

.welcome-inner {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.welcome-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 24rpx;
}

.welcome-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 10rpx;
}

.welcome-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 28rpx;
}

.welcome-example {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.15);
  padding: 14rpx 24rpx;
  border-radius: 40rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.example-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
}

.example-text {
  font-size: 24rpx;
  color: #fff;
}

/* ========== Messages ========== */
.message-wrapper {
  display: flex;
  margin-bottom: 20rpx;
  animation: fadeIn 0.3s ease;
}

.user-wrapper {
  justify-content: flex-end;
}

.ai-wrapper {
  justify-content: flex-start;
  align-items: flex-start;
}

.user-bubble {
  max-width: 70%;
  padding: 22rpx 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx 24rpx 6rpx 24rpx;
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-word;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.3);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ========== AI Chat Mode ========== */
.chat-mode {
  display: flex;
  padding: 10rpx 0;
  align-items: flex-start;
}

.butler-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E0E7FF 0%, #C7D2FE 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.15);
}

.butler-avatar.small {
  width: 56rpx;
  height: 56rpx;
  font-size: 28rpx;
}

.chat-bubble {
  position: relative;
  margin-left: 16rpx;
  background-color: #fff;
  padding: 20rpx 24rpx;
  border-radius: 6rpx 24rpx 24rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  max-width: 75%;
}

.bubble-arrow {
  position: absolute;
  left: -12rpx;
  top: 0;
  width: 0;
  height: 0;
  border-top: 12rpx solid #fff;
  border-left: 12rpx solid transparent;
}

.chat-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

/* ========== Typing Indicator ========== */
.typing-bubble {
  padding: 20rpx 32rpx;
  margin-left: 16rpx;
}

.typing-indicator {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  background: #9CA3AF;
  border-radius: 50%;
  animation: typing 1.4s infinite ease-in-out;
}

.typing-dot:nth-child(1) { animation-delay: 0s; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }

@keyframes typing {
  0%, 60%, 100% {
    transform: translateY(0);
    opacity: 0.4;
  }
  30% {
    transform: translateY(-10rpx);
    opacity: 1;
  }
}

/* ========== Bill Card ========== */
.bill-card-mode {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin: 10rpx 0;
  width: 580rpx;
  max-width: 85%;
  border-left: 6rpx solid #10B981;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
  animation: slideUp 0.3s ease-out;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.success-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.card-header-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #10B981;
}

.bill-main {
  padding-top: 4rpx;
}

.bill-amount {
  text-align: center;
  margin-bottom: 20rpx;
}

.bill-amount .symbol {
  font-size: 32rpx;
  color: #6B7280;
}

.bill-amount .value {
  font-size: 56rpx;
  font-weight: bold;
  color: #111827;
}

.bill-divider {
  height: 1rpx;
  background: #F3F4F6;
  margin-bottom: 16rpx;
}

.bill-info {
  padding-top: 4rpx;
}

.bill-info .info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.bill-info .info-item:last-child {
  margin-bottom: 0;
}

.bill-info .info-item .label {
  color: #9CA3AF;
}

.bill-info .info-item .tag {
  background: linear-gradient(135deg, #E0E7FF 0%, #C7D2FE 100%);
  color: #4338CA;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.bill-info .info-item .val {
  color: #374151;
  font-weight: 500;
}

.bill-footer {
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed #E5E7EB;
  text-align: center;
}

.bill-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ========== Input Area ========== */
.input-area {
  display: flex;
  align-items: flex-end;
  background-color: #fff;
  padding: 16rpx 20rpx;
  padding-bottom: calc(126rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F3F4F6;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
  gap: 12rpx;
}

.auto-textarea {
  flex: 1;
  width: 100%;
  min-height: 44rpx;
  max-height: 200rpx;
  background-color: #F3F4F6;
  border-radius: 24rpx;
  padding: 16rpx 28rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.send-btn {
  width: auto;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 36rpx;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(102, 126, 234, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-btn.disabled {
  background: linear-gradient(135deg, #D1D5DB 0%, #9CA3AF 100%);
  box-shadow: none;
  color: #fff;
}
