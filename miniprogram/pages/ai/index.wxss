page {
  height: 100%;
  background-color: #f7f7f7;
}

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f7f7f7;
}

.scroll-area {
  flex: 1;
  height: 0;
  box-sizing: border-box;
}

.chat-content {
  padding: 30rpx;
  min-height: 100%;
  display: flex;
  flex-direction: column;
}

.bottom-spacer {
  height: 40rpx;
  width: 100%;
}

.welcome-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  margin-top: 40rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.welcome-tip text {
  font-size: 32rpx;
  color: #333333;
  line-height: 1.6;
}

.welcome-sub {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #999999;
}

.welcome-example {
  margin-top: 24rpx;
  padding: 20rpx 30rpx;
  background: #f0f2ff;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #667eea;
}

.message-wrapper {
  display: flex;
  margin-bottom: 15rpx;
  animation: fadeIn 0.3s ease;
}

.user-wrapper {
  justify-content: flex-end;
}

.ai-wrapper {
  justify-content: flex-start;
}

.user-bubble {
  max-width: 70%;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx 20rpx 6rpx 20rpx;
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-word;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.ai-bubble {
  max-width: 70%;
  padding: 24rpx 30rpx;
  background: #ffffff;
  border-radius: 20rpx 20rpx 20rpx 6rpx;
  color: #333333;
  font-size: 30rpx;
  line-height: 1.5;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.typing-bubble {
  padding: 24rpx 36rpx;
}

.typing-indicator {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  background: #999999;
  border-radius: 50%;
  animation: typing 1.4s infinite ease-in-out;
}

.typing-dot:nth-child(1) {
  animation-delay: 0s;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% {
    transform: translateY(0);
    opacity: 0.4;
  }
  30% {
    transform: translateY(-10rpx);
    opacity: 1;
  }
}

.receipt-card {
  width: 580rpx;
  max-width: 85%;
  background: linear-gradient(145deg, #ffffff 0%, #f8f9ff 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.15), 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 1px solid rgba(102, 126, 234, 0.1);
}

.receipt-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.receipt-icon {
  font-size: 48rpx;
}

.receipt-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
  letter-spacing: 4rpx;
}

.receipt-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #667eea, transparent);
  margin-bottom: 24rpx;
  border-radius: 2rpx;
}

.receipt-body {
  display: flex;
  flex-direction: column;
}

.receipt-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.receipt-label {
  font-size: 28rpx;
  color: #999999;
  font-weight: 500;
}

.receipt-value {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.amount {
  font-size: 44rpx !important;
  color: #ff6b6b !important;
  font-weight: 700 !important;
  letter-spacing: 2rpx;
}

.category-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.receipt-footer {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed #e0e0e0;
  text-align: center;
}

.receipt-time {
  font-size: 24rpx;
  color: #bbbbbb;
}

.input-area {
  display: flex;
  align-items: flex-end;
  background-color: #fff;
  padding: 12rpx 10rpx 10rpx;
  border-top: 1rpx solid #eeeeee;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.02);
}

.auto-textarea {
  flex: 1;
  width: 100%;
  min-height: 40rpx;
  max-height: 200rpx;
  
  background-color: #f4f5f7;
  border-radius: 24rpx;
  padding: 16rpx 30rpx;
  box-sizing: border-box;
  
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.send-btn {
  width: 30rpx;
  height: 72rpx;
  line-height: 1;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
  margin-left: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-btn.disabled {
  background: #d0d0d0;
  box-shadow: none;
  color: #ffffff;
}

.chat-mode {
  display: flex;
  padding: 10rpx 20rpx;
  animation: slideUp 0.3s ease-out;
}

.butler-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e1f5fe;
  border: 2rpx solid #b3e5fc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.chat-bubble {
  position: relative;
  margin-left: 25rpx;
  background-color: #fff;
  padding: 10rpx 18rpx 8rpx;
  border-radius: 0 24rpx 24rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  max-width: 75%;
}

.bubble-arrow {
  position: absolute;
  left: -15rpx;
  top: 0;
  width: 0;
  height: 0;
  border-top: 15rpx solid #fff;
  border-left: 15rpx solid transparent;
}

.chat-content {
  font-size: 28rpx;
  line-height: 1.3;
  color: #333;
  margin: 0;
  padding: 0;
}

.bill-card-mode {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 10rpx 20rpx;
  width: calc(100% - 40rpx);
  border-left: 8rpx solid #07c160;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.08);
  animation: slideUp 0.3s ease-out;
}

.bill-card-mode .card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  color: #07c160;
}

.success-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #07c160;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.bill-main {
  padding-top: 20rpx;
}

.bill-amount {
  text-align: center;
  margin-bottom: 30rpx;
}

.bill-amount .symbol {
  font-size: 36rpx;
  color: #666;
}

.bill-amount .value {
  font-size: 60rpx;
  font-weight: bold;
  color: #333;
}

.bill-info {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
}

.bill-info .info-item {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.bill-info .info-item .label {
  color: #999;
}

.bill-info .info-item .tag {
  background: #e8f5e9;
  color: #2e7d32;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.bill-info .info-item .val {
  color: #333;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
