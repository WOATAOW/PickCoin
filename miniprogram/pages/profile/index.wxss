page {
  background-color: #F3F4F6;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  margin: 0;
  padding: 0;
  min-height: 100vh;
}

.container {
  width: 100%;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  background-color: #F3F4F6;
  padding: 24rpx;
  padding-bottom: calc(130rpx + env(safe-area-inset-bottom));
  gap: 24rpx;
}

/* ========== User Card ========== */
.user-card {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%);
  border-radius: 28rpx;
  padding: 40rpx;
  box-shadow: 0 12rpx 36rpx rgba(30, 58, 138, 0.3);
  overflow: hidden;
}

.card-bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.08;
  background: #fff;
}

.card-bg-circle.c1 {
  width: 220rpx;
  height: 220rpx;
  top: -60rpx;
  right: -40rpx;
}

.card-bg-circle.c2 {
  width: 140rpx;
  height: 140rpx;
  bottom: -20rpx;
  left: -20rpx;
}

.card-inner {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
}

.avatar-btn {
  margin: 0;
  padding: 0;
  background: none;
  border: none;
  width: 120rpx;
  height: 120rpx;
  margin-right: 28rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.avatar-btn::after {
  border: none;
}

.avatar-btn.disabled {
  pointer-events: none;
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
}

.avatar-placeholder {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
  display: flex;
  justify-content: center;
  align-items: center;
}

.avatar-placeholder.gray {
  background-color: rgba(255, 255, 255, 0.15);
}

.placeholder-icon {
  font-size: 56rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.nickname-input-wrap {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  padding: 0 24rpx;
}

.nickname-input {
  width: 100%;
  height: 64rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
  background: transparent;
}

.nickname-placeholder {
  font-size: 32rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.6);
  line-height: 64rpx;
}

.user-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* ========== Stats Card ========== */
.stats-card {
  width: 100%;
  box-sizing: border-box;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1E3A8A;
  margin-bottom: 8rpx;
}

.stat-value.debt {
  color: #EF4444;
}

.stat-label {
  font-size: 24rpx;
  color: #9CA3AF;
}

.stat-divider {
  width: 1rpx;
  height: 72rpx;
  background-color: #F3F4F6;
}

/* ========== Menu Card ========== */
.menu-card {
  width: 100%;
  box-sizing: border-box;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 4rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon-circle {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-icon-circle.green-bg {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
}

.menu-icon-circle.blue-bg {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
}

.menu-icon-circle.purple-bg {
  background: linear-gradient(135deg, #E0E7FF 0%, #C7D2FE 100%);
}

.menu-icon {
  font-size: 32rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #1F2937;
  font-weight: 500;
}

.menu-arrow {
  font-size: 36rpx;
  color: #D1D5DB;
}

.menu-divider {
  height: 1rpx;
  background-color: #F3F4F6;
  margin-left: 88rpx;
}

/* ========== Buttons ========== */
.btn-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  flex: 1;
  justify-content: flex-end;
}

.save-btn {
  width: 100%;
  box-sizing: border-box;
  background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%);
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  border: none;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(30, 58, 138, 0.35);
}

.save-btn[loading] {
  color: rgba(255, 255, 255, 0.7);
  box-shadow: 0 4rpx 12rpx rgba(30, 58, 138, 0.2);
}

.logout-btn {
  width: 100%;
  box-sizing: border-box;
  background: #FFFFFF;
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 500;
  color: #EF4444;
  border: 2rpx solid #FEE2E2;
  letter-spacing: 2rpx;
}

.logout-btn::after {
  border: none;
}

.login-btn {
  width: 100%;
  box-sizing: border-box;
  background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%);
  border-radius: 48rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(30, 58, 138, 0.35);
  border: none;
  margin-top: auto;
}
