<view class="container">
  <view class="header-section">
    <view class="filter-row">
      <picker mode="date" fields="month" bindchange="onMonthChange">
        <view class="picker-btn">
          <text class="picker-text">{{selectedMonth}}</text>
          <text class="picker-icon">▼</text>
        </view>
      </picker>
      
      <picker mode="selector" range="{{categories}}" bindchange="onCategoryChange">
        <view class="picker-btn">
          <text class="picker-text">{{selectedCategory}}</text>
          <text class="picker-icon">▼</text>
        </view>
      </picker>
    </view>

    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-label">支出</text>
        <text class="stat-value expense">-¥{{monthExpense}}</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-label">收入</text>
        <text class="stat-value income">+¥{{monthIncome}}</text>
      </view>
    </view>
  </view>

  <view class="list-section">
    <view wx:if="{{isEmpty}}" class="empty-state">
      <view class="empty-icon">📭</view>
      <text class="empty-text">暂无账单记录</text>
      <text class="empty-hint">该月暂无收支明细</text>
    </view>

    <view wx:else class="tx-list">
      <view wx:for="{{groupedBills}}" wx:key="date" wx:for-item="group" class="date-group">
        <view class="date-header">
          <text class="date-text">{{group.date}}</text>
          <view class="date-summary">
            <text class="summary-item expense">支出 ¥{{group.dayTotalExpense.toFixed(2)}}</text>
            <text class="summary-item income">收入 ¥{{group.dayTotalIncome.toFixed(2)}}</text>
          </view>
        </view>
        
        <view 
          wx:for="{{group.records}}" 
          wx:key="_id" 
          wx:for-item="bill" 
          class="tx-item"
          bindtap="openEditBillModal"
          data-bill="{{bill}}"
        >
          <view class="tx-icon-wrap">
            <text class="tx-icon">{{bill.type === '支出' || bill.type === 'expense' ? '💸' : '💰'}}</text>
          </view>
          <view class="tx-info">
            <text class="tx-category">{{bill.category}}</text>
            <text class="tx-detail">{{bill.account || '账户'}} - {{bill.remark || '-'}}</text>
          </view>
          <view class="tx-right">
            <text class="tx-time">{{bill.time}}</text>
            <text class="tx-amount {{bill.type === '支出' || bill.type === 'expense' ? 'expense' : 'income'}}">
              {{bill.type === '支出' || bill.type === 'expense' ? '-' : '+'}}¥{{bill.amountText}}
            </text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="mask {{showEditModal ? 'show' : ''}}" bindtap="closeEditModal"></view>

  <view class="modal {{showEditModal ? 'show' : ''}}">
    <view class="modal-header">
      <text class="modal-title">修改账单金额</text>
    </view>

    <view class="modal-body">
      <view class="hint-text">
        <text class="hint-label">当前分类：</text>
        <text class="hint-value">{{editingBill ? editingBill.category : ''}}</text>
      </view>
      <view class="hint-text">
        <text class="hint-label">原金额：</text>
        <text class="hint-value">{{editingBill ? (editingBill.type === '支出' || editingBill.type === 'expense' ? '-' : '+') + '¥' + editingBill.amountText : ''}}</text>
      </view>

      <view class="input-group">
        <text class="input-label">新金额</text>
        <input 
          class="modal-input" 
          type="digit" 
          placeholder="请输入新金额" 
          bindinput="onNewAmountInput" 
          value="{{newAmount}}"
        />
      </view>
    </view>

    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="closeEditModal">取消</view>
      <view class="modal-btn confirm" bindtap="submitEditBill">保存修改</view>
    </view>
  </view>
</view>