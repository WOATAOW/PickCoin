page {
  background-color: #F3F4F6;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  margin: 0;
  padding: 0;
  width: 100vw;
  min-height: 100vh;
  box-sizing: border-box;
  overflow-x: hidden;
}

.container {
  width: 100vw;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  overflow-x: hidden;
  padding-bottom: calc(130rpx + env(safe-area-inset-bottom));
}

/* ========== Header ========== */
.header-section {
  position: relative;
  background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%);
  padding: 40rpx 32rpx 48rpx;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 10rpx 30rpx rgba(30, 58, 138, 0.25);
  overflow: hidden;
}

.header-bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.08;
  background: #fff;
}

.header-bg-circle.c1 {
  width: 240rpx;
  height: 240rpx;
  top: -60rpx;
  right: -40rpx;
}

.header-bg-circle.c2 {
  width: 160rpx;
  height: 160rpx;
  bottom: 20rpx;
  left: -30rpx;
}

.header-inner {
  position: relative;
  z-index: 1;
}

.filter-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.picker-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background-color: rgba(255, 255, 255, 0.15);
  padding: 14rpx 24rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.picker-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.picker-icon {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.7);
}

.stats-card {
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 10rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
}

.stat-value.expense {
  color: #FCA5A5;
}

.stat-value.income {
  color: #86EFAC;
}

.stat-divider {
  width: 1rpx;
  height: 56rpx;
  background-color: rgba(255, 255, 255, 0.15);
  flex-shrink: 0;
}

/* ========== List Section ========== */
.list-section {
  flex: 1;
  padding: 24rpx;
  margin-top: -20rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* ========== Transaction List ========== */
.tx-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.date-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.date-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 8rpx;
}

.date-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}

.date-summary {
  display: flex;
  gap: 20rpx;
}

.summary-item {
  font-size: 22rpx;
}

.summary-item.expense {
  color: #EF4444;
}

.summary-item.income {
  color: #10B981;
}

.tx-item {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  padding: 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.tx-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.tx-icon-wrap.bg-red {
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
}

.tx-icon-wrap.bg-green {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
}

.tx-icon {
  font-size: 36rpx;
}

.tx-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.tx-category {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tx-detail {
  font-size: 22rpx;
  color: #9CA3AF;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tx-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.tx-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.tx-amount {
  font-size: 32rpx;
  font-weight: 700;
}

.tx-amount.expense {
  color: #EF4444;
}

.tx-amount.income {
  color: #10B981;
}

/* ========== Mask & Modal ========== */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.mask.show {
  opacity: 1;
  visibility: visible;
}

.modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 620rpx;
  background-color: #FFFFFF;
  border-radius: 28rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  z-index: 101;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  overflow: hidden;
}

.modal.show {
  opacity: 1;
  pointer-events: auto;
  transform: translate(-50%, -50%) scale(1);
}

.modal-handle {
  width: 64rpx;
  height: 8rpx;
  background: #D1D5DB;
  border-radius: 4rpx;
  margin: 20rpx auto 0;
}

.modal-header {
  padding: 24rpx 40rpx 0;
  text-align: center;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #111827;
}

.modal-body {
  padding: 32rpx 40rpx;
}

.hint-card {
  background: #F9FAFB;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 28rpx;
}

.hint-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.hint-label {
  font-size: 26rpx;
  color: #6B7280;
}

.hint-value {
  font-size: 26rpx;
  color: #111827;
  font-weight: 500;
}

.hint-value.expense-text {
  color: #EF4444;
}

.hint-value.income-text {
  color: #10B981;
}

.input-group {
  margin-bottom: 0;
}

.input-label {
  display: block;
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 14rpx;
}

.modal-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #111827;
  background-color: #F9FAFB;
  transition: border-color 0.2s, background-color 0.2s;
}

.modal-input:focus {
  border-color: #3B82F6;
  background-color: #FFFFFF;
}

.modal-input::placeholder {
  color: #9CA3AF;
}

.modal-footer {
  display: flex;
  padding: 0 40rpx 36rpx;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.modal-btn.cancel {
  background-color: #F3F4F6;
  color: #6B7280;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
  color: #FFFFFF;
  box-shadow: 0 8rpx 20rpx rgba(59, 130, 246, 0.3);
}
