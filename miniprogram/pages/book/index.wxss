page {
  background-color: #F3F4F6;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  margin: 0;
  padding: 0;
  width: 100vw;
  min-height: 100vh;
  box-sizing: border-box;
  overflow-x: hidden;
}

.container {
  width: 100vw;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding: 0;
  padding-bottom: calc(130rpx + env(safe-area-inset-bottom));
  margin: 0;
  overflow-x: hidden;
}

/* ========== Header ========== */
.header {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%);
  padding: 32rpx 32rpx 48rpx;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 10rpx 30rpx rgba(30, 58, 138, 0.25);
  overflow: hidden;
}

.header-bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.08;
  background: #fff;
}

.header-bg-circle.c1 {
  width: 220rpx;
  height: 220rpx;
  top: -60rpx;
  right: -40rpx;
}

.header-bg-circle.c2 {
  width: 140rpx;
  height: 140rpx;
  bottom: 0;
  left: -20rpx;
}

.header-inner {
  position: relative;
  z-index: 1;
}

.type-switch {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 40rpx;
  padding: 6rpx;
}

.switch-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 36rpx;
  font-size: 28rpx;
  font-weight: 500;
  background-color: transparent;
  color: rgba(255, 255, 255, 0.6);
  transition: all 0.25s;
}

.switch-btn.active {
  background-color: #FFFFFF !important;
  color: #1E3A8A !important;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.switch-btn.expense.active {
  background-color: #FFFFFF !important;
  color: #EF4444 !important;
}

.switch-btn.income.active {
  background-color: #FFFFFF !important;
  color: #10B981 !important;
}

.amount-section {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 8rpx;
}

.amount-symbol {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
}

.amount-value {
  font-size: 88rpx;
  color: #FFFFFF;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.amount-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

/* ========== Form Section ========== */
.form-section {
  width: 100%;
  box-sizing: border-box;
  flex: 1;
  padding: 24rpx;
}

.form-card {
  width: 100%;
  box-sizing: border-box;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 4rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.form-item {
  width: 100%;
  box-sizing: border-box;
  padding: 24rpx 0;
}

.form-item-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.form-divider {
  height: 1rpx;
  background-color: #F3F4F6;
}

.form-label {
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
}

.picker-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.picker-text {
  font-size: 28rpx;
  color: #6B7280;
}

.picker-arrow {
  font-size: 32rpx;
  color: #D1D5DB;
  font-weight: 300;
}

/* ========== AA Section ========== */
.aa-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.aa-left {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.aa-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.aa-label {
  font-size: 22rpx;
  color: #9CA3AF;
}

.switch-wrap {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.switch-track {
  width: 80rpx;
  height: 44rpx;
  background-color: #E5E7EB;
  border-radius: 22rpx;
  position: relative;
  transition: background-color 0.25s;
}

.switch-track.on {
  background-color: #1E3A8A;
}

.switch-thumb {
  width: 36rpx;
  height: 36rpx;
  background-color: #FFFFFF;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.15);
  transition: left 0.25s;
}

.switch-track.on .switch-thumb {
  left: 40rpx;
}

.switch-text {
  font-size: 26rpx;
  color: #6B7280;
}

.people-counter {
  display: flex;
  align-items: center;
  gap: 0;
  background-color: #F3F4F6;
  border-radius: 30rpx;
  overflow: hidden;
}

.counter-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #1E3A8A;
}

.counter-btn:active {
  background-color: #E5E7EB;
}

.counter-value {
  min-width: 56rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #1F2937;
}

/* ========== Remark Input ========== */
.remark-input {
  width: 100%;
  height: 88rpx;
  padding: 0 20rpx;
  background-color: #F9FAFB;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #374151;
  box-sizing: border-box;
  border: 2rpx solid #F3F4F6;
  transition: border-color 0.2s;
}

.remark-input:focus {
  border-color: #3B82F6;
  background-color: #FFFFFF;
}

.remark-input::placeholder {
  color: #9CA3AF;
}

/* ========== Submit Button ========== */
.bottom-submit {
  width: 100vw;
  padding: 0 24rpx;
  box-sizing: border-box;
  background-color: #F3F4F6;
  overflow: hidden;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #1E3A8A 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.35);
}

.submit-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* ========== Mask & Keyboard ========== */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: rgba(0, 0, 0, 0.3);
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.mask.show {
  opacity: 1;
  pointer-events: auto;
}

.keyboard-popup {
  position: fixed;
  bottom: calc(110rpx + env(safe-area-inset-bottom));
  left: 0;
  width: 100vw;
  z-index: 1000;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  overflow: hidden;
}

.keyboard-popup.show {
  transform: translateY(0);
}

.keyboard-handle {
  width: 64rpx;
  height: 8rpx;
  background: #D1D5DB;
  border-radius: 4rpx;
  margin: 16rpx auto 8rpx;
  background-color: #fff;
}

.keyboard-section {
  width: 100vw;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-template-rows: repeat(4, 110rpx);
  background-color: #F3F4F6;
  padding: 0;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid #E5E7EB;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.key {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 44rpx;
  font-weight: 500;
  background-color: #FFFFFF;
  color: #1F2937;
  border-right: 1rpx solid #E5E7EB;
  border-bottom: 1rpx solid #E5E7EB;
  box-sizing: border-box;
}

.key:active {
  background-color: #E5E7EB;
}

.key-del {
  color: #EF4444;
  background-color: #F9FAFB;
  font-size: 36rpx;
}

.key-date {
  font-size: 28rpx;
  background-color: #F9FAFB;
  color: #6B7280;
}

.key-zero {
  grid-column: span 2;
}

.key-submit {
  grid-row: span 2;
  background: linear-gradient(180deg, #3B82F6 0%, #1E3A8A 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.key-submit:active {
  background: linear-gradient(180deg, #2563EB 0%, #1E3A8A 100%);
}
