page {
  background-color: #F3F4F6;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  margin: 0;
  padding: 0;
  width: 100vw;
  min-height: 100vh;
  box-sizing: border-box;
  overflow-x: hidden;
}

.container {
  width: 100vw;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  overflow-x: hidden;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== Header ========== */
.header-section {
  position: relative;
  background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%);
  padding: 48rpx 32rpx 40rpx;
  border-radius: 0 0 48rpx 48rpx;
  box-shadow: 0 10rpx 30rpx rgba(30, 58, 138, 0.25);
  overflow: hidden;
}

.header-bg-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.08;
  background: #fff;
}

.header-bg-circle.c1 {
  width: 240rpx;
  height: 240rpx;
  top: -60rpx;
  right: -40rpx;
}

.header-bg-circle.c2 {
  width: 160rpx;
  height: 160rpx;
  bottom: 20rpx;
  left: -30rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  margin-bottom: 28rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.stat-card-on-header {
  position: relative;
  z-index: 1;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(10px);
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.stat-label-on-header {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 8rpx;
}

.stat-num-on-header {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}

.header-divider {
  height: 1rpx;
  background: rgba(255, 255, 255, 0.15);
  margin-bottom: 20rpx;
}

.stat-meta-row {
  display: flex;
  justify-content: space-between;
}

.stat-meta-item {
  display: flex;
  flex-direction: column;
}

.meta-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 6rpx;
}

.meta-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

/* ========== Tabs ========== */
.tabs {
  display: flex;
  padding: 24rpx;
  gap: 16rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 22rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 2rpx solid #E5E7EB;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
  border-color: transparent;
  box-shadow: 0 8rpx 20rpx rgba(59, 130, 246, 0.3);
}

.tab-item.active .tab-text {
  color: #fff;
  font-weight: 600;
}

.tab-text {
  font-size: 28rpx;
  color: #6B7280;
}

.tab-badge {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  background: #EF4444;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-item.active .tab-badge {
  background: #fff;
  color: #3B82F6;
}

/* ========== List Section ========== */
.list-section {
  flex: 1;
  padding: 0 24rpx 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #EFF6FF 0%, #DBEAFE 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #374151;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* ========== Debt List ========== */
.debt-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.debt-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 28rpx 28rpx 28rpx 0;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
  position: relative;
}

.debt-accent {
  width: 6rpx;
  height: 100%;
  min-height: 80rpx;
  background: linear-gradient(180deg, #10B981 0%, #059669 100%);
  border-radius: 0 3rpx 3rpx 0;
  margin-right: 22rpx;
  flex-shrink: 0;
}

.debt-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.debt-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.debt-icon.bg-green {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
}

.debt-icon.bg-red {
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
}

.debt-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.debt-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.debt-remark {
  font-size: 24rpx;
  color: #9CA3AF;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.debt-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.debt-amount {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.debt-amount.income {
  color: #10B981;
}

.debt-amount.expense {
  color: #EF4444;
}

.debt-date {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* ========== Mask & Modal ========== */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.mask.show {
  opacity: 1;
  visibility: visible;
}

.modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 16rpx 32rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.1);
}

.modal.show {
  transform: translateY(0);
}

.modal-handle {
  width: 64rpx;
  height: 8rpx;
  background: #D1D5DB;
  border-radius: 4rpx;
  margin: 0 auto 24rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 28rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #111827;
}

.close-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F3F4F6;
  border-radius: 50%;
  font-size: 28rpx;
  color: #6B7280;
}

/* Modal Amount Card */
.modal-amount-card {
  background: linear-gradient(135deg, #F0FDF4 0%, #DCFCE7 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
  text-align: center;
}

.modal-amount-label {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 8rpx;
}

.modal-amount-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #10B981;
  margin-bottom: 12rpx;
}

.modal-amount-status {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.modal-amount-status.pending {
  background: #FEF3C7;
  color: #D97706;
}

.modal-amount-status.settled {
  background: #D1FAE5;
  color: #059669;
}

/* Detail Rows */
.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  font-size: 28rpx;
  color: #6B7280;
}

.detail-value {
  font-size: 28rpx;
  color: #1F2937;
  font-weight: 500;
  max-width: 60%;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-value.amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #10B981;
}

.detail-value.pending {
  color: #F59E0B;
}

.detail-value.settled {
  color: #10B981;
}

/* Modal Footer */
.modal-footer {
  margin-top: 32rpx;
}

.settle-btn,
.close-modal-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.settle-btn {
  background: linear-gradient(135deg, #10B981 0%, #059669 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.35);
}

.close-modal-btn {
  background: #F3F4F6;
  color: #6B7280;
}
