<view class="container">
  <!-- Loading 骨架屏 -->
  <block wx:if="{{isLoading}}">
    <view class="skeleton-card">
      <view class="skeleton-line w40"></view>
      <view class="skeleton-line w60 h-large"></view>
      <view class="skeleton-divider"></view>
      <view class="skeleton-row">
        <view class="skeleton-line w30"></view>
        <view class="skeleton-line w30"></view>
      </view>
    </view>
    <view class="skeleton-actions">
      <view class="skeleton-btn"></view>
      <view class="skeleton-btn"></view>
    </view>
    <view class="skeleton-list">
      <view class="skeleton-item" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
    </view>
  </block>

  <!-- 正式内容 -->
  <block wx:else>
    <view class="dashboard-card" bindtap="goToAccounts">
      <view class="card-bg-circle c1"></view>
      <view class="card-bg-circle c2"></view>
      <view class="card-inner">
        <view class="card-header">
          <text class="greeting">{{greeting}}</text>
          <text class="title">本月结余 (元)</text>
        </view>
        <view class="net-value">¥{{totalBalance}}</view>

        <view class="divider"></view>

        <view class="assets-row">
          <view class="asset-item">
            <text class="asset-label">本月支出</text>
            <text class="asset-value expense">-¥{{monthExpense}}</text>
          </view>
          <view class="asset-divider"></view>
          <view class="asset-item">
            <text class="asset-label">本月收入</text>
            <text class="asset-value income">+¥{{monthIncome}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="action-bar">
      <view class="action-btn" bindtap="goToQuickBook">
        <view class="action-icon-circle blue-bg">
          <text class="action-icon">✍️</text>
        </view>
        <text class="btn-text">记一笔</text>
        <text class="btn-sub">快速记账</text>
      </view>
      <view class="action-btn ai-btn" bindtap="goToAiAgent">
        <view class="action-icon-circle purple-bg">
          <text class="action-icon">🤖</text>
        </view>
        <text class="btn-text">AI 管家</text>
        <text class="btn-sub">智能分析</text>
      </view>
    </view>

    <view class="tx-section">
      <view class="tx-header">
        <view class="tx-title-wrap">
          <text class="tx-title">最近流水</text>
          <text class="tx-count" wx:if="{{recentTxs.length > 0}}">{{recentTxs.length}}笔</text>
        </view>
        <view class="tx-more-btn" bindtap="goToAllTxs">
          <text class="tx-more-text">查看全部</text>
          <text class="tx-more-arrow">›</text>
        </view>
      </view>

      <view class="tx-list">
        <block wx:for="{{recentTxs}}" wx:key="txId">
          <view class="tx-item">
            <view class="tx-icon-wrap {{item.type === 'expense' ? 'bg-red' : 'bg-green'}}">
              <text class="tx-icon">{{item.type === 'expense' ? '💸' : '💰'}}</text>
            </view>
            <view class="tx-info">
              <text class="tx-category">{{item.category}}</text>
              <text class="tx-account">{{item.account}}</text>
            </view>
            <view class="tx-right">
              <text class="tx-amount {{item.type === 'expense' ? 'text-expense' : 'text-income'}}">
                {{item.type === 'expense' ? '-' : '+'}}{{item.amount}}
              </text>
              <text class="tx-date">{{item.date}}</text>
            </view>
          </view>
        </block>

        <view class="empty-state" wx:if="{{recentTxs.length === 0}}">
          <view class="empty-icon-wrap">
            <text class="empty-icon">📭</text>
          </view>
          <text class="empty-text">暂无流水记录</text>
          <text class="empty-hint">点击上方「记一笔」开始记录你的第一笔账单</text>
        </view>
      </view>
    </view>
  </block>
</view>
